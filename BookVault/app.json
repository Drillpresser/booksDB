{
  "expo": {
    "name": "BookVault",
    "slug": "bookvault",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "bookvault",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bookvault.app",
      "infoPlist": {
        "UIDesignRequiresCompatibility": true
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "BookVault uses your camera to scan book barcodes."
        }
      ]
    ]
  }
}
