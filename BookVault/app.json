{
  "expo": {
    "name": "BookHoarder",
    "slug": "bookvault",
    "owner": "drillpress",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF3E0"
    },
    "orientation": "portrait",
    "scheme": "bookvault",
    "newArchEnabled": true,
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bookvault.app",
      "infoPlist": {
        "UIDesignRequiresCompatibility": true,
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "9",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.bookvault.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF3E0"
      }
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "BookHoarder uses your camera to scan book barcodes."
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "89985565-afad-4d23-b42d-2e13c2356f53"
      }
    }
  }
}
