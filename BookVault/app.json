{
  "expo": {
    "name": "BookHoarder",
    "slug": "bookvault",
    "owner": "drillpress",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "scheme": "bookvault",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bookvault.app",
      "newArchEnabled": false,
      "infoPlist": {
        "UIDesignRequiresCompatibility": true,
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "BookVault uses your camera to scan book barcodes."
        }
      ],
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "89985565-afad-4d23-b42d-2e13c2356f53"
      }
    }
  }
}
